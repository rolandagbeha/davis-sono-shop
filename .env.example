# ──────────────────────────────────────
# Davis Sono Shop — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ──────────────────────────────────────

# Neon (obligatoire — Console Neon > Auth > Configuration / Data API)
VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.c-x.region.aws.neon.tech/neondb/auth
VITE_NEON_DATA_API_URL=https://ep-xxx.apirest.c-x.region.aws.neon.tech/neondb/rest/v1
# Mêmes valeurs, côté serveur (fonctions /api, sans le préfixe VITE_)
NEON_AUTH_URL=https://ep-xxx.neonauth.c-x.region.aws.neon.tech/neondb/auth
NEON_DATA_API_URL=https://ep-xxx.apirest.c-x.region.aws.neon.tech/neondb/rest/v1
# Connexion Postgres directe (pooled, "Connection string" dans Neon Console >
# Dashboard). Utilisée par api/_db.ts pour le catalogue public, le checkout et
# les devis — le Data API exige un jeton même pour un visiteur anonyme sur ce
# projet, donc ces routes publiques passent en direct par Postgres.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.c-x.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Vercel Blob (upload images produit) — généré automatiquement quand un store
# Blob est rattaché au projet sur Vercel ; en local, récupérer le token dans
# Vercel > Storage > Blob > Connect (ou `vercel env pull`).
BLOB_READ_WRITE_TOKEN=

# Assistant IA (Anthropic) — aussi utilisée par le rapport hebdomadaire
ANTHROPIC_API_KEY=

# Rapport hebdomadaire automatique (api/weekly-report.ts, déclenché par
# Vercel Cron — voir "crons" dans vercel.json et HANDOFF_CLAUDE_CODE.md)
# Jeton arbitraire (générer une valeur aléatoire longue) : Vercel l'envoie
# automatiquement en en-tête Authorization lors de ses appels Cron.
CRON_SECRET=
# SendGrid (envoi de l'email de rapport) — clé API et expéditeur vérifié
# (Single Sender Verification ou domaine authentifié, voir SendGrid Console)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Adresse qui reçoit le rapport hebdomadaire (le gérant)
REPORT_TO_EMAIL=

# WhatsApp (numéro du gérant, avec indicatif pays)
VITE_WHATSAPP_NUMBER=22898423232
